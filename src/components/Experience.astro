---
import { experiences } from "../data/experience";
---

<section id="experience" class="px-6 py-24">
  <div class="mx-auto max-w-7xl">
    <div class="mb-12 text-center">
      <h2 class="mb-2 font-mono text-sm text-primary">Where I've worked</h2>
      <h3 class="text-3xl font-bold text-white">Professional Experience</h3>
    </div>

    <div class="space-y-6">
      {experiences.map((exp) => (
        <div class="group rounded-2xl border border-neutral-800 bg-neutral-900/50 overflow-hidden transition-colors hover:border-neutral-700">
          <div class="flex flex-col md:flex-row">
            <div class="relative h-48 w-full overflow-hidden md:h-auto md:w-64 shrink-0">
              <img
                src={exp.image}
                alt={exp.company}
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-neutral-950/40" />
            </div>

            <div class="flex-1 p-8">
              <div class="mb-1 flex flex-wrap items-center gap-3">
                <h4 class="text-xl font-semibold text-white">{exp.company}</h4>
                {exp.period.includes("Present") && (
                  <span class="rounded-full bg-primary/10 px-3 py-0.5 text-xs font-medium text-primary">
                    Current
                  </span>
                )}
              </div>
              <p class="mb-1 text-sm text-neutral-500">{exp.industry}</p>
              <p class="mb-1 font-mono text-sm text-primary">{exp.role}</p>
              <p class="mb-4 text-xs text-neutral-600">{exp.period}</p>

              <ul class="space-y-2">
                {exp.highlights.map((h) => (
                  <li class="flex gap-2 text-sm text-neutral-400">
                    <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-primary/50" />
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
