---
import { Image } from "astro:assets";
import SocialLinks from "./SocialLinks.astro";
import heroBg from "../../public/images/pictures/gran_via.jpg";
import avatar from "../../public/images/danibaena.jpg";
---

<section class="relative flex min-h-screen items-center justify-center px-6 pt-20">
  {/* Background image with gradient overlay */}
  <div class="absolute inset-0 -z-10">
    <Image
      src={heroBg}
      alt=""
      class="h-full w-full object-cover"
      widths={[640, 1024, 1440]}
      sizes="100vw"
      quality={75}
      loading="eager"
      aria-hidden="true"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-neutral-950/80 via-neutral-950/70 to-neutral-950"
    >
    </div>
  </div>

  <div class="mx-auto max-w-4xl text-center">
    <div class="mb-8">
      <Image
        src={avatar}
        alt="Daniel Baena"
        class="mx-auto h-36 w-36 rounded-full border-2 border-neutral-700 object-cover shadow-lg"
        width={288}
        height={288}
        quality={80}
        loading="eager"
      />
    </div>

    <h1 class="mb-4 text-5xl font-bold tracking-tight text-white sm:text-6xl">Daniel Baena</h1>

    <p class="text-primary mb-2 font-mono text-lg sm:text-xl">Staff Product Engineer</p>

    <p class="mx-auto mb-4 max-w-2xl text-lg text-neutral-300">
      10+ years building products end-to-end. High ownership, product-minded, and deeply technical.
      Based in Madrid, remotely available.
    </p>

    <p class="mx-auto mb-8 max-w-xl text-sm text-neutral-400">
      Open to contracting opportunities — US, UK & worldwide. Past experience working with
      international teams across time zones.
    </p>

    <div class="mb-10 flex flex-wrap items-center justify-center gap-4">
      <a
        href="#contact"
        class="bg-primary hover:bg-primary-light rounded-lg px-6 py-3 font-medium text-neutral-950 transition-colors"
      >
        Get in touch
      </a>
      <a
        href="#experience"
        class="rounded-lg border border-neutral-500/50 bg-neutral-900/30 px-6 py-3 font-medium text-neutral-200 backdrop-blur-sm transition-colors hover:border-neutral-400 hover:text-white"
      >
        View experience
      </a>
    </div>

    <SocialLinks />
  </div>
</section>
