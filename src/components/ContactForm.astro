---

---

<section id="contact" class="px-6 py-24">
  <div class="mx-auto max-w-2xl">
    <div class="mb-12 text-center">
      <h2 class="text-primary mb-2 font-mono text-sm">Get in touch</h2>
      <h3 class="text-3xl font-bold text-white">Contact me</h3>
    </div>

    <form action="https://formspree.io/f/xoqprjne" method="POST" class="space-y-6">
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="name" class="mb-2 block text-sm text-neutral-400">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Everyone has one right?"
            class="focus:border-primary w-full rounded-lg border border-neutral-800 bg-neutral-900/50 px-4 py-3 text-sm text-white placeholder-neutral-600 transition-colors outline-none"
          />
        </div>
        <div>
          <label for="email" class="mb-2 block text-sm text-neutral-400">Email</label>
          <input
            type="email"
            id="email"
            name="_replyto"
            required
            placeholder="your_username@your_fancy_domain.com"
            class="focus:border-primary w-full rounded-lg border border-neutral-800 bg-neutral-900/50 px-4 py-3 text-sm text-white placeholder-neutral-600 transition-colors outline-none"
          />
        </div>
      </div>

      <div>
        <label for="message" class="mb-2 block text-sm text-neutral-400">Message</label>
        <textarea
          id="message"
          name="message"
          rows="6"
          required
          placeholder="Hey Dani, I want to reach out to you to talk about..."
          class="focus:border-primary w-full resize-none rounded-lg border border-neutral-800 bg-neutral-900/50 px-4 py-3 text-sm text-white placeholder-neutral-600 transition-colors outline-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="bg-primary hover:bg-primary-light w-full rounded-lg px-6 py-3 font-medium text-neutral-950 transition-colors sm:w-auto"
      >
        Send message
      </button>
    </form>
  </div>
</section>
