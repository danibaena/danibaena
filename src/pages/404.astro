---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<Layout title="404 — Page not found">
  <Header />
  <main class="flex min-h-screen items-center justify-center px-6 pt-20">
    <div class="text-center">
      <p class="text-primary mb-4 font-mono text-8xl font-bold">404</p>
      <h1 class="mb-4 text-2xl font-bold text-white">Page not found</h1>
      <p class="mb-8 text-neutral-400">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="bg-primary hover:bg-primary-light inline-block rounded-lg px-6 py-3 font-medium text-neutral-950 transition-colors"
      >
        Back to home
      </a>
    </div>
  </main>
  <Footer />
</Layout>
