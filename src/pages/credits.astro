---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<Layout title="Credits — Daniel Baena">
  <Header />
  <main class="px-6 pt-32 pb-24">
    <div class="mx-auto max-w-2xl">
      <div class="mb-12 text-center">
        <h1 class="text-primary mb-2 font-mono text-sm">Acknowledgments</h1>
        <h2 class="text-3xl font-bold text-white">Credits</h2>
      </div>

      <div class="rounded-2xl border border-neutral-800 bg-neutral-900/50 p-8">
        <ul class="space-y-4 text-neutral-400">
          <li>
            Some images from
            <a
              href="https://unsplash.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary hover:text-primary-light">Unsplash</a
            >
          </li>
          <li>Madrid pictures are my own</li>
          <li>
            Favicon created with
            <a
              href="https://favicon.io"
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary hover:text-primary-light">favicon.io</a
            >
          </li>
          <li>
            Contact form managed with
            <a
              href="https://formspree.io"
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary hover:text-primary-light">Formspree</a
            >
          </li>
          <li>
            Built with
            <a
              href="https://astro.build"
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary hover:text-primary-light">Astro</a
            >
            and
            <a
              href="https://tailwindcss.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary hover:text-primary-light">Tailwind CSS</a
            >
          </li>
        </ul>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
