---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects, openSourceContributions } from "../data/projects";
import "../styles/global.css";
---

<Layout title="Projects — Daniel Baena">
  <Header />
  <main class="px-6 pt-32 pb-24">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12 text-center">
        <h1 class="mb-2 font-mono text-sm text-primary">Side projects</h1>
        <h2 class="text-3xl font-bold text-white">Things I've built</h2>
      </div>

      <div class="mb-24 grid gap-6 sm:grid-cols-2">
        {projects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>

      <div class="mb-12 text-center">
        <h2 class="mb-2 font-mono text-sm text-primary">Giving back</h2>
        <h3 class="text-3xl font-bold text-white">Open Source Contributions</h3>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        {openSourceContributions.map((contrib) => (
          <a
            href={contrib.url}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-2xl border border-neutral-800 bg-neutral-900/50 p-8 transition-colors hover:border-neutral-700"
          >
            <h4 class="mb-2 text-lg font-semibold text-white">{contrib.name}</h4>
            <p class="text-sm text-neutral-400">{contrib.description}</p>
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
